{
  "version": "0.6.0",
  "source": "./index.html",
  "type": "module",
  "name": "pga-fatec",
  "description": "Projeto para facilitar o desenvolvimento do PGA das Fatecs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "deploy": "gh-pages -d dist",
    "predeploy": "npm run build",
    "docker:build": "docker build --build-arg VITE_API_URL=${VITE_API_URL:-http://localhost:3000} -t pga-frontend .",
    "docker:run": "docker run -d -p 80:80 --name pga-frontend-container pga-frontend",
    "docker:stop": "docker stop pga-frontend-container",
    "docker:remove": "docker rm pga-frontend-container",
    "docker:clean": "npm run docker:stop && npm run docker:remove",
    "docker:restart": "npm run docker:clean && npm run docker:run",
    "docker:compose:up": "docker-compose up -d",
    "docker:compose:down": "docker-compose down",
    "docker:compose:build": "docker-compose build",
    "docker:compose:logs": "docker-compose logs -f",
    "docker:build:dev": "VITE_API_URL=http://localhost:3000 npm run docker:build"
  },
  "dependencies": {
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.12",
    "@radix-ui/react-toast": "^1.2.14",
    "axios": "^1.9.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.453.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.8.1",
    "tailwind-merge": "^2.5.4"
  },
  "devDependencies": {
    "@types/react": "18.2.0",
    "@types/react-dom": "18.2.0",
    "@vitejs/plugin-react": "4.3.4",
    "esbuild": "^0.25.4",
    "gh-pages": "^6.3.0",
    "globals": "15.12.0",
    "tailwindcss": "3.4.16",
    "vite": "^6.3.5"
  },
  "alias": {
    "@/*": "./src/components/ui/$1"
  }
}
